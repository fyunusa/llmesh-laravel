{
    "name": "llmesh/laravel",
    "description": "First-class Laravel integration for LLMesh — the flexible PHP LLM SDK",
    "license": "MIT",
    "type": "library",
    "keywords": ["laravel", "llm", "openai", "anthropic", "ai", "llmesh"],
    "repositories": [
        {
            "type": "path",
            "url": "../llmesh",
            "options": {
                "symlink": true
            }
        }
    ],
    "authors": [
        {
            "name": "LLMesh Contributors",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "llmesh/core": "dev-main || ^0.1",
        "laravel/framework": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "LLMesh\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LLMesh\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LLMesh\\Laravel\\LLMeshServiceProvider"
            ],
            "aliases": {
                "LLMesh": "LLMesh\\Laravel\\Facades\\LLMesh"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
